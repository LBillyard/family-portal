[Unit]
Description=Family Portal — hourly auto-sync (Google Calendar + banks)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/family-portal
Environment=PYTHONUNBUFFERED=1
Environment=ENV=production
EnvironmentFile=-/opt/family-portal/.env
ExecStart=/opt/family-portal/venv/bin/python -m server.jobs.auto_sync
