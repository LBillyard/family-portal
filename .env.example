# Family Portal — environment variables
# Copy to .env and fill in values

# development | production (production disables /docs, reload, and requires a strong SECRET_KEY)
ENV=development

# Required for production
SECRET_KEY=change-me-to-a-long-random-string
PUBLIC_URL=http://localhost:8090

# Google Calendar OAuth (https://console.cloud.google.com/apis/credentials)
# Create OAuth 2.0 Client ID → Web application
# Authorized redirect URI: http://localhost:8090/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8090/api/auth/google/callback

# OpenRouter AI — holiday ideas + assistant + receipt OCR (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini

# Email renewal reminders (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL=

# TrueLayer Open Banking — Starling, Revolut, Amex, Virgin (https://console.truelayer.com)
# Redirect URI: http://localhost:8090/api/banking/callback
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
TRUELAYER_REDIRECT_URI=http://localhost:8090/api/banking/callback
TRUELAYER_ENV=sandbox

# WhatsApp — Meta (Facebook) Cloud API (https://developers.facebook.com → WhatsApp)
# TOKEN: a permanent access token for the system user with whatsapp_business_messaging
# PHONE_NUMBER_ID: from WhatsApp → API Setup
# VERIFY_TOKEN: any secret you choose; paste the same value into the webhook config
# APP_SECRET: App → Settings → Basic (used to verify inbound message signatures)
# Webhook callback URL to register: https://<your-domain>/api/whatsapp/webhook
# TEMPLATE_NAME: an approved UTILITY template with a single {{1}} body variable
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_TEMPLATE_NAME=daily_digest
WHATSAPP_TEMPLATE_LANG=en_GB
