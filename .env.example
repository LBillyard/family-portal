# Family Portal — environment variables
# Copy to .env and fill in values

# development | production (production disables /docs, reload, and requires a strong SECRET_KEY)
ENV=development

# Required for production
SECRET_KEY=change-me-to-a-long-random-string
PUBLIC_URL=http://localhost:8090

# Fresh-DB seed password for the two household accounts.
# Leave empty to auto-generate a random one (logged once at seed time).
FAMILY_PORTAL_SEED_PASSWORD=

# SQLite database path override (default: data/family.db; tests use a temp DB)
FAMILY_PORTAL_DB=

# Google Calendar OAuth (https://console.cloud.google.com/apis/credentials)
# Create OAuth 2.0 Client ID → Web application
# Authorized redirect URI: http://localhost:8090/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8090/api/auth/google/callback

# OpenRouter AI — holiday ideas + assistant + receipt OCR (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini

# Email renewal reminders (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# From address on outgoing mail (falls back to SMTP_USER when empty)
SMTP_FROM=
# STARTTLS on the SMTP connection — set false only if your server doesn't support it
SMTP_TLS=true
NOTIFY_EMAIL=

# TrueLayer Open Banking — Starling, Revolut, Amex, Virgin (https://console.truelayer.com)
# Redirect URI: http://localhost:8090/api/banking/callback
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
TRUELAYER_REDIRECT_URI=http://localhost:8090/api/banking/callback
TRUELAYER_ENV=sandbox

# WhatsApp — pick a provider: "twilio" (default) or "meta"
WHATSAPP_PROVIDER=twilio

# Daily weather in the morning digest (Open-Meteo, no API key). Leave blank to omit.
# Find coords by searching your town on https://www.latlong.net or open-meteo.com
WEATHER_LATITUDE=
WEATHER_LONGITUDE=
WEATHER_LABEL=

# --- Twilio WhatsApp (https://console.twilio.com) ---
# SID + AUTH_TOKEN: Console dashboard. FROM: the sandbox number (whatsapp:+14155238886)
# or your approved sender. Inbound webhook to set in Twilio: https://<domain>/api/whatsapp/twilio
# CONTENT_SID: (optional) an approved Content template with one {{1}} var — needed for the
# proactive 7am digest on a production sender (the sandbox sends free-form).
# TWILIO_VALIDATE=false temporarily skips signature checks during first setup.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_CONTENT_SID=
TWILIO_VALIDATE=true

# --- Meta (Facebook) Cloud API — alternative provider ---
# Webhook callback URL to register: https://<your-domain>/api/whatsapp/webhook
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_TEMPLATE_NAME=daily_digest
WHATSAPP_TEMPLATE_LANG=en_GB
